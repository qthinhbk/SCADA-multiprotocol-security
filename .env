# Environment variables for docker-compose
# This ensures ZEEK_INTERFACE is always set to "any" for packet capture

# Zeek packet capture interface
# "any" captures traffic from all network interfaces (required for DNP3 detection)
ZEEK_INTERFACE=any

# PCAP rotation interval in seconds (default: 15)
# Lower = faster detection but more files for Zeek to process
# Higher = slower detection but less processing overhead
# Recommended: 15 seconds for balance between MTTD and performance
PCAP_ROTATION_SECONDS=15
